@page
@model ZnaykoAI.Pages.Quizzes.IndexModel
@{
    ViewData["Title"] = "My Quizzes";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="h2 mb-1">My Quizzes</h1>
            <p class="text-muted mb-0">Your saved quizzes, newest first.</p>
        </div>
        <a class="btn btn-primary" asp-page="/Quizzes/Generate">Generate Quiz</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="alert">
            @successMessage
        </div>
    }

    @if (Model.Quizzes.Count == 0)
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <p class="text-muted mb-3">You have not created any quizzes yet.</p>
                <a class="btn btn-primary" asp-page="/Quizzes/Generate">Generate your first quiz</a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="list-group list-group-flush">
                @foreach (var quiz in Model.Quizzes)
                {
                    <div class="list-group-item">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                            <div>
                                <h2 class="h5 mb-1">
                                    <a asp-page="/Quizzes/Details" asp-route-id="@quiz.Id" class="text-decoration-none">
                                        @quiz.Title
                                    </a>
                                </h2>
                                <p class="text-muted small mb-1">
                                    Grade @quiz.Grade · @quiz.Subject · @quiz.SubTopic
                                </p>
                                <p class="text-muted small mb-0">
                                    @quiz.Questions.Count question(s) ·
                                    Created @quiz.CreatedOn.ToLocalTime().ToString("g")
                                </p>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-sm btn-outline-primary" asp-page="/Quizzes/Details" asp-route-id="@quiz.Id">
                                    Open
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@quiz.Id"
                                      onsubmit="return confirm('Delete this quiz? This cannot be undone.');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
