@page
@model ZnaykoAI.Pages.Quizzes.GenerateModel
@{
    ViewData["Title"] = "Generate Quiz";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="h2 mb-1">Generate Quiz</h1>
            <p class="text-muted mb-4">
                Generate a quiz with AI. Saved quizzes open on the printable details page.
            </p>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="Input.Grade" class="form-label"></label>
                                <input asp-for="Input.Grade" class="form-control" type="number" min="1" max="12" />
                                <span asp-validation-for="Input.Grade" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.QuestionCount" class="form-label"></label>
                                <input asp-for="Input.QuestionCount" class="form-control" type="number" min="1" max="50" />
                                <span asp-validation-for="Input.QuestionCount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.AnswersPerQuestion" class="form-label"></label>
                                <input asp-for="Input.AnswersPerQuestion" class="form-control" type="number" min="2" max="6" />
                                <span asp-validation-for="Input.AnswersPerQuestion" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Subject" class="form-label"></label>
                                <input asp-for="Input.Subject" class="form-control" placeholder="e.g. Математика" />
                                <span asp-validation-for="Input.Subject" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.SubTopic" class="form-label"></label>
                                <input asp-for="Input.SubTopic" class="form-control" placeholder="e.g. Дроби" />
                                <span asp-validation-for="Input.SubTopic" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                Generate with AI
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
